# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — used to call Claude Sonnet for job fit evaluation
ANTHROPIC_API_KEY=sk-ant-...

# Notion integration token — create at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# Notion database ID — the ID of your Job Tracker database
# Found in the database URL: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional — Notifications ─────────────────────────────────────────────────

# Slack incoming webhook URL for the daily digest
# Create at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Optional — Pipeline tuning ────────────────────────────────────────────────

# Minimum fit score (0–100) for a role to be logged to Notion
# Roles below this threshold are evaluated but not written to Notion
# Default: 60
FIT_SCORE_THRESHOLD=60
